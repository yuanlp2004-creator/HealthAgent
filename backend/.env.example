# App environment
APP_ENV=dev
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Database: default SQLite for local dev; switch to postgres for docker
DATABASE_URL=sqlite:///./healthagent.db
# DATABASE_URL=postgresql+psycopg://health:health@postgres:5432/healthagent

# JWT
JWT_SECRET=please-change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OCR: baidu (default, requires AK/SK) or paddle (offline fallback)
OCR_ENGINE=baidu
BAIDU_OCR_AK=
BAIDU_OCR_SK=

# 通义千问 VL 作为 OCR 兜底复检（百度云识别缺字段时自动触发）
DASHSCOPE_API_KEY=
DASHSCOPE_VL_MODEL=qwen-vl-plus
DASHSCOPE_TIMEOUT=30.0
OCR_VLM_FALLBACK=true

# --- RAG / 大模型问诊（DashScope OpenAI 兼容接口，复用同一 DASHSCOPE_API_KEY）---
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_EMBEDDING_DIM=1024
LLM_TEMPERATURE=0.3
LLM_CACHE_DIR=.cache/llm
RAG_KB_DB_PATH=storage/kb.sqlite
RAG_TOP_K=5
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
